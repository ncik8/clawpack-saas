<button onclick="navigator.clipboard.writeText(document.getElementById('social-strategy-box').innerText)" style="background:#28a745;color:white;border:none;padding:12px 24px;border-radius:6px;cursor:pointer;font-size:14px;font-weight:bold;margin-bottom:10px;">📋 Click to Copy</button><br />
